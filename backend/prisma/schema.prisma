// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum GameStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

enum FriendshipStatus {
	ACCEPTED
	WAITING
}

model User {
	id						String		@id @default(uuid())
	username				String		@unique
	password				String
	// salt					String  	@unique
	// inscription_date		DateTime 	@default(now())
	// status					Int			@default(0)

	player					Player?
	stats					StatsUser?
	// gamesWon				Game[]		@relation("GameWinner")
	// gamesPlayed				GamePlayer[]
	// friendships				Friend[]	@relation("FriendPlayer")
	// friendOf				Friend[]	@relation("FriendTarget")

	sentFriendships			Friendship[]	@relation("FriendshipRequest")
	receivedFriendships		Friendship[]	@relation("FriendshipAnswered")
}

model Game {
	id							String		@id @default(uuid())
	players						Player[]
	//rounds					Round[]		???
	// winner_id				String
	// winner					User	@relation("GameWinner", fields: [winner_id], references: [id])
	// played_at				DateTime
	// times_ms					BigInt
	// score_total				Int
	// nb_total_played_cards	Int
}

model Player {
	id							Int		@id @default(autoincrement())

	game_id						String
	game						Game	@relation(fields: [game_id], references: [id])

	user_id						String	@unique
	user						User	@relation(fields: [user_id], references: [id])

	score						Int		@default(0)
	// nb_stack_cards				Int		@default(0)
	// nb_cards_played				Int		@default(0)
}

model StatsUser	{
	player						User	@relation(fields: [player_id], references: [id])
	player_id					String	@id
	nb_games					Int		@default(0)
	nb_victories				Int		@default(0)
	nb_defeats					Int		@default(0)
	rank						Int		@default(0)
	rank_max					Int		@default(0)
	favorite_card				String	@default("None")
	avg_reaction_ms				Int		@default(0)
	most_smashed_card			String	@default("None")
	most_combo_smash			String	@default("None")
	nb_smash					Int		@default(0)
	nb_smash_success			Int		@default(0)
	max_win_streak				Int		@default(0)
	max_loose_streak			Int		@default(0)
	max_smash_success_streak	Int		@default(0)
	hours_played				Int		@default(0)
	nb_bonus_played				Int		@default(0)
}

model Friendship {
	id							Int		@id @default(autoincrement())
	
	request_id					String
	requester					User	@relation("FriendshipRequest", fields: [request_id], references: [id], onDelete: Cascade)

	received_id					String
	receiver					User	@relation("FriendshipAnswered", fields: [received_id], references: [id],onDelete: Cascade)

	status						FriendshipStatus	@default(WAITING)

	//Pour empecher les doublons d'une meme paire
	@@unique([request_id, received_id])
}
